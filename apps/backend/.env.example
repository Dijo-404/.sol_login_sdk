# Node environment
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Solana network
# One of: mainnet-beta, devnet, testnet
SOLANA_NETWORK=devnet
# Use a paid RPC for production (Helius, QuickNode, Triton, etc.)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Helius enhanced transactions API key
# Get one at https://www.helius.dev — required for reputation scoring
HELIUS_API_KEY=

# JWT signing
# Generate with: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRY=24h

# Postgres connection string
# Local dev: docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres:16
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sol_login?schema=public

# Comma-separated origins allowed to call this API (no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173

# Deployed Anchor program ID — see programs/sol-login/src/lib.rs and docs/anchor-deploy.md
SOL_LOGIN_PROGRAM_ID=

# Base58-encoded keypair secret for the backend issuer wallet (or JSON byte array)
# Generate with: solana-keygen new --no-bip39-passphrase -o issuer.json
# Then: cat issuer.json | jq -r '. | tojson'
SOL_LOGIN_SIGNER_KEY=

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20

# Set by deploy pipeline
GIT_COMMIT=
