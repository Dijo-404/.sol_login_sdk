# Node environment
NODE_ENV=production
PORT=4000
LOG_LEVEL=info

# Solana network
# One of: mainnet-beta, devnet, testnet
SOLANA_NETWORK=mainnet-beta
# Use a paid RPC for production (Helius, QuickNode, Triton, etc.)
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Helius enhanced transactions API key
# Get one at https://www.helius.dev — required for reputation scoring
HELIUS_API_KEY=

# JWT signing
# Generate with: openssl rand -base64 48
JWT_SECRET=

# JWT expiry duration
JWT_EXPIRY=24h

# Postgres connection string
# Supabase:  postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Railway:   postgresql://postgres:[password]@[host].railway.app:5432/railway
# Render:    postgresql://[user]:[password]@[host]/sol_login
DATABASE_URL=

# Comma-separated origins allowed to call this API (no trailing slash)
# Example: https://your-app.vercel.app,https://yourdomain.com
ALLOWED_ORIGINS=

# Deployed Anchor program ID — see programs/sol-login/src/lib.rs and docs/anchor-deploy.md
SOL_LOGIN_PROGRAM_ID=

# Base58-encoded keypair secret for the backend issuer wallet (or JSON byte array)
# Generate with: solana-keygen new --no-bip39-passphrase -o issuer.json
# Then: cat issuer.json | jq -r '. | tojson'
SOL_LOGIN_SIGNER_KEY=

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20

# Set by deploy pipeline
GIT_COMMIT=
